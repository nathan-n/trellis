rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is a member of the circle
    function isCircleMember(circleId) {
      return exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    // Helper: get user's role in the circle
    function getCircleRole(circleId) {
      return get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role;
    }

    // Helper: check minimum role level
    function hasMinRole(circleId, minRole) {
      let role = getCircleRole(circleId);
      return minRole == 'readonly' ? true
        : minRole == 'professional' ? role in ['admin', 'family', 'professional']
        : minRole == 'family' ? role in ['admin', 'family']
        : minRole == 'admin' ? role == 'admin'
        : false;
    }

    // User profiles — restricted field updates (F5)
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'activeCircleId', 'updatedAt', 'circleIds']);
    }

    // Invitations — invitee can accept/decline, admin can revoke
    match /invitations/{invitationId} {
      allow read: if request.auth != null && (
        request.auth.token.email.lower() == resource.data.inviteeEmail
        || isCircleMember(resource.data.circleId)
      );
      allow create: if request.auth != null && hasMinRole(request.resource.data.circleId, 'admin');
      allow update: if request.auth != null && (
        // Invitee can accept or decline their own pending invitation
        (
          request.auth.token.email.lower() == resource.data.inviteeEmail
          && resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'declined']
          && request.resource.data.role == resource.data.role
          && request.resource.data.circleId == resource.data.circleId
          && request.resource.data.invitedByUid == resource.data.invitedByUid
          && request.resource.data.inviteeEmail == resource.data.inviteeEmail
        )
        // Admin can revoke (set to expired)
        || (
          hasMinRole(resource.data.circleId, 'admin')
          && request.resource.data.status == 'expired'
        )
      );
    }

    // Circles
    match /circles/{circleId} {
      // Soft-deleted circles are hidden from reads (except audit traversal by admin).
      allow read: if request.auth != null && isCircleMember(circleId) && (
        !('deletedAt' in resource.data) || resource.data.deletedAt == null
        || hasMinRole(circleId, 'admin')
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && hasMinRole(circleId, 'admin');

      // Members — admin can manage, self-join with non-admin role
      match /members/{memberId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && (
          // Existing admin adding a member
          (isCircleMember(circleId) && hasMinRole(circleId, 'admin'))
          // Self-join: user creating their own member doc, cannot grant admin
          || (request.auth.uid == memberId && request.resource.data.role != 'admin')
        );
        allow update: if request.auth != null && (
          hasMinRole(circleId, 'admin')
          // Self-update own doc (e.g., retry after partial acceptance), cannot escalate to admin
          || (request.auth.uid == memberId && request.resource.data.role != 'admin')
        );
        allow delete: if request.auth != null && hasMinRole(circleId, 'admin');
      }

      // Tasks (with visibility) — createdByUid must match auth (F9)
      match /tasks/{taskId} {
        allow read: if request.auth != null && isCircleMember(circleId) && (
          !('visibility' in resource.data)
          || resource.data.visibility == 'circle'
          || getCircleRole(circleId) == 'admin'
          || request.auth.uid == resource.data.createdByUid
          || (request.auth.uid in resource.data.visibleToUids)
        );
        allow create: if request.auth != null && hasMinRole(circleId, 'professional')
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if request.auth != null && hasMinRole(circleId, 'professional');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.createdByUid
        );

        match /comments/{commentId} {
          allow read: if request.auth != null && isCircleMember(circleId) && (
            !('visibility' in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data)
            || get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibility == 'circle'
            || getCircleRole(circleId) == 'admin'
            || request.auth.uid == get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.createdByUid
            || (request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibleToUids)
          );
          allow create: if request.auth != null && hasMinRole(circleId, 'professional');
          allow update: if request.auth != null && request.auth.uid == resource.data.authorUid;
          allow delete: if request.auth != null && (
            request.auth.uid == resource.data.authorUid || hasMinRole(circleId, 'admin')
          );
        }

        match /attachments/{attachmentId} {
          allow read: if request.auth != null && isCircleMember(circleId) && (
            !('visibility' in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data)
            || get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibility == 'circle'
            || getCircleRole(circleId) == 'admin'
            || request.auth.uid == get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.createdByUid
            || (request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibleToUids)
          );
          allow create: if request.auth != null && hasMinRole(circleId, 'professional');
          allow delete: if request.auth != null && (
            hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.uploadedByUid
          );
        }

        // Doctor questions
        match /questions/{questionId} {
          allow read: if request.auth != null && isCircleMember(circleId) && (
            !('visibility' in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data)
            || get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibility == 'circle'
            || getCircleRole(circleId) == 'admin'
            || request.auth.uid == get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.createdByUid
            || (request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)/tasks/$(taskId)).data.visibleToUids)
          );
          allow create: if request.auth != null && isCircleMember(circleId);
          allow update: if request.auth != null && isCircleMember(circleId);
          allow delete: if request.auth != null && hasMinRole(circleId, 'admin');
        }
      }

      // Visits
      match /visits/{visitId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'professional');
        allow update: if request.auth != null && hasMinRole(circleId, 'professional');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin')
          || request.auth.uid == resource.data.caregiverUid
          || ('createdByUid' in resource.data && request.auth.uid == resource.data.createdByUid)
        );
      }

      // Medications
      match /medications/{medicationId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'family');
        allow update: if request.auth != null && hasMinRole(circleId, 'family');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.createdByUid
        );

        match /administrationLog/{logId} {
          allow read: if request.auth != null && isCircleMember(circleId);
          allow create: if request.auth != null && hasMinRole(circleId, 'professional');
        }
      }

      // Care Logs
      match /careLogs/{logId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'professional');
        allow update: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.authorUid
        );
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.authorUid
        );
      }

      // Emergency Profile
      match /emergencyProfile/{docId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'family');
        allow update: if request.auth != null && hasMinRole(circleId, 'family');
      }

      // Documents
      match /documents/{docId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'family');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.uploadedByUid
        );
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'family');
        allow update: if request.auth != null && hasMinRole(circleId, 'family');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.paidByUid
        );
      }

      // Caregiver Resources
      match /resources/{resourceId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && hasMinRole(circleId, 'family');
        allow update: if request.auth != null && hasMinRole(circleId, 'family');
        allow delete: if request.auth != null && (
          hasMinRole(circleId, 'admin') || request.auth.uid == resource.data.addedByUid
        );
      }

      // Wellbeing Check-ins (private to author, admin can view for sparklines)
      match /wellbeingCheckins/{checkinId} {
        allow read: if request.auth != null && (
          request.auth.uid == resource.data.authorUid
          || getCircleRole(circleId) == 'admin'
        );
        allow create: if request.auth != null && isCircleMember(circleId)
          && request.resource.data.authorUid == request.auth.uid;
      }

      // Audit Log (append-only, actorUid must match auth — F6)
      match /auditLog/{logId} {
        allow read: if request.auth != null && isCircleMember(circleId);
        allow create: if request.auth != null && isCircleMember(circleId)
          && request.resource.data.actorUid == request.auth.uid;
      }
    }
  }
}
